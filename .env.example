UOCC_ENV=local
UOCC_BIND_HOST=127.0.0.1
UOCC_WEB_PORT=3000
UOCC_API_PORT=8000
UOCC_AGENT_PORT=8787

# Local development fallback. docker-compose overrides this with PostgreSQL.
DATABASE_URL=sqlite:///./data/uocc.sqlite3

# Compose default:
# DATABASE_URL=postgresql://uocc:uocc@db:5432/uocc
POSTGRES_USER=uocc
POSTGRES_PASSWORD=uocc
POSTGRES_DB=uocc

ALLOWLIST_PATH=/app/config/allowlist.yaml
APP_CONFIG_PATH=/app/config/app.yaml

# auto: try the agent, then use demo data locally when unavailable.
# remote: require AGENT_BASE_URL to be reachable.
# demo: never call the agent.
AGENT_MODE=auto
AGENT_BASE_URL=http://agent:8787
AGENT_TIMEOUT_SECONDS=5

# Agent backend:
# demo: deterministic sample data only.
# local: use fixed safe host commands from the allowlist.
AGENT_BACKEND=demo
LOG_DEFAULT_LINES=200
LOG_MAX_LINES=1000
